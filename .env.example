# Copy this file to .env and fill in your values. Do not commit .env.
# For Cursor MCP you can also set these in the MCP server config instead.

SUPERSET_URL=https://your-superset-instance.com

# Use one of the following:

# Session cookie (when you only have cookie, e.g. Google login): get from DevTools -> Application -> Cookies -> session value
# SUPERSET_SESSION_COOKIE=session=<paste value>

# Or JWT token
# SUPERSET_ACCESS_TOKEN=your_token

# Or username/password
# SUPERSET_USERNAME=your_username
# SUPERSET_PASSWORD=your_password
